    { "source": "/sights", "destination": "/en/pages/visitas", "permanent": true },
    { "source": "/sights/", "destination": "/en/pages/visitas", "permanent": true },
    { "source": "/visitas", "destination": "/pages/visitas", "permanent": true },
    { "source": "/visitas/", "destination": "/pages/visitas", "permanent": true },
